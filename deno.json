{
  "$schema": "https://jsr.io/schema/config-file.v1.json",
  "name": "@tijs/atproto-oauth",
  "version": "2.10.0",
  "license": "MIT",
  "exports": "./mod.ts",
  "publish": {
    "include": [
      "mod.ts",
      "src/**/*.ts",
      "docs/**/*.md",
      "README.md",
      "LICENSE"
    ],
    "exclude": [
      "**/*.test.ts",
      "npm/",
      "_build_npm.ts",
      "_build_import_map.json"
    ]
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1.0.16",
    "@tijs/oauth-client-deno": "jsr:@tijs/oauth-client-deno@5.1.0",
    "@tijs/atproto-sessions": "jsr:@tijs/atproto-sessions@2.1.0",
    "@tijs/atproto-storage": "jsr:@tijs/atproto-storage@1.1.0",
    "@atproto/syntax": "npm:@atproto/syntax@0.3.0"
  },
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true
  },
  "tasks": {
    "test": "deno test --allow-all src/",
    "check": "deno check mod.ts",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "quality": "deno fmt && deno lint && deno check mod.ts",
    "ci": "deno task quality && deno task test",
    "build:npm": "deno run -A _build_npm.ts"
  }
}